<apex:page renderAs="pdf" showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false" standardController="Order" extensions="NattOrderSummaryFormController" readOnly="true"> 
    <html>
        <head>
            <style>
                @page 
                {
                size: letter;
                margin: 10mm;
                border: 2px solid black;   
                
                
                @top-center 
                {
                content: element(header);
                }
                
                @bottom-center 
                {
                content: "Page " counter(page) " of " counter(pages);
                }
                }
                div.header {
                padding: 10px;
                text-align:center;
                background-color:#D3D3D3;
                }
                .page-break 
                {
                display:block;
                page-break-after:always;
                }
                .boldFormat
                {
                font-weight:bold;
                }
                body
                {
                font-family: Arial Unicode MS;
                }
                
                #wrapper {
                width:100%;
                border: 1px solid black;
                overflow: auto;
                
                }
                #first {
                width:50%;
                border: 1px solid red;
                display: inline-block;
                
                }
                #second {
                width:50%;
                border: 1px solid green;
                
                
                }
                #table-bordered {
                border: 1px solid #000;
                border-collapse: collapse;
                }
                #tdStyle {
                vertical-align:center;
                border: 1px solid #000;
                border-spacing: 0;
                }
                PageBlockBorder{
                border:0.8px solid black;
                }
                #tdStyleTable2{
                width:10%;
                vertical-align:center;
                border:1px solid #000;
                cellspacing:0;
                cellpadding:0;
                font-size:9pt;
                text-align:center;
                }
                
                #tdStyleTable3
                {
                vertical-align:center;
                border:1px solid #000;
                cellspacing:0;
                cellpadding:0;
                font-size:9pt;
                text-align:left;
                }
                
                #tdStyleTable4
                {
                vertical-align:center;
                border:1px solid #000;
                cellspacing:0;
                cellpadding:0;
                font-size:9pt;
                text-align:left;
                }
                
                table.list
                {
                border-width: 0 !important;
                }
                
                /*tr.dataRow.last td 
                {
                border-bottom-width: 0 !important;
                } */
                
                .headerRow .headerclass{text-align:center;}  
                
                tableRowStyle 
                {        
                border-bottom-width: 0 !important;
                }
                #ttd{
                border: 1px solid black;
                border-collapse: collapse;
                }
                #dco{
                border: 1px solid black;
                border-collapse: collapse;
                }
                #oof{
                border: 1px solid black;
                border-collapse: collapse;
                }
                #merg{
                margin: 10mm;
                border: 2px solid black; 
                }
            </style>
        </head>
        
        <div class="header">
            <div>ORDER SUMMARY</div>
        </div>
        
        <body></body>
    </html>
    
