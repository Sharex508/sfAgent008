        </apex:pageBlock>
        
        <table width="100%" id="table-bordered">
            <tr>
                <th Style="background-color:#D3D3D3;" id="tdStyleTable4">Complete Order History</th>
            </tr>
        </table> 
        
        <apex:pageBlock >
            <apex:pageBlockTable value="{!orderSummaryList}" var="fh" width="100%" style="border: 2px solid #000 ; border-bottom:2px solid #000 important;font-size:9pt;"  rendered="{!orderSummaryList.size>0}" styleClass="tableStyle">
                <apex:column value="{!fh.qty}" style="width:10%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:center;" headerValue="Qty"  headerClass="headerclass"  />
                <apex:column value="{!fh.ProdName}" style="width:50%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:left;" headerValue="Product" headerClass="headerclass" />
                <apex:column value="{!fh.createdDate}" style="width:13%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:center;" headerValue="Date Created" headerClass="headerclass" />
                <apex:column value="{!fh.OrderNumber}" style="width:13%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:center;" headerValue="Order Number" headerClass="headerclass" />
                <apex:column value="{!fh.OrderType}" style="width:14%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:center;" headerValue="Order Type" headerClass="headerclass" />          
            </apex:pageBlockTable>
        </apex:pageBlock>
        <table width="100%" id="table-bordered">
            <tr>
                <th Style="background-color:#D3D3D3;" id="tdStyleTable4">Requested Ship Date History</th>
            </tr>
        </table> 
        
        <apex:pageBlock >
            <apex:pageBlockTable value="{!lstRSDChangeLogs}" var="cl" width="100%" style="border: 2px solid #000 ; border-bottom:2px solid #000 important;font-size:9pt;"  rendered="{!lstRSDChangeLogs.size>0}" styleClass="tableStyle">
                <apex:column value="{!cl.NATT_Unit__c}" style="width:50%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:center;" headerValue="Unit" headerClass="headerclass" />
                <apex:column style="width:25%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:center;" headerValue="Original Value" headerClass="headerclass">
                    <apex:outputText escape="true" value="{!JSENCODE(cl.NATT_Original_Value__c)}"/>
                </apex:column>
                <apex:column style="width:25%;vertical-align:center;border:1px solid #000;cellspacing:0;cellpadding:0;font-size:9pt;text-align:center;" headerValue="New Value" headerClass="headerclass">
                    <apex:outputText escape="true" value="{!JSENCODE(cl.NATT_New_Value__c)}"/>
                </apex:column>
            </apex:pageBlockTable>
        </apex:pageBlock>
    </apex:form>
</apex:page>