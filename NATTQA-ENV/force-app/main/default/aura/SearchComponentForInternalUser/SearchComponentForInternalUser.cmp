<!--Created by LTI to search unit information-->

<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes,force:hasRecordId,lightning:isUrlAddressable" controller ="UnitInformationCallout" access="global">
    
    <aura:attribute name="recordExist" type="Boolean" default="false"/>
    <aura:attribute name="searchKey" type="String"/>
    <aura:attribute name="responseData" type="List"/>
    <aura:attribute name="unitDetails" type="object"/>
    <aura:attribute name="majorCmp" type="List"/>
    <aura:attribute name="warrantyCoverage" type="List"/>
    <aura:attribute name="fieldAction" type="List"/>
    <aura:attribute name="claims" type="List"/>
    <aura:attribute name="upComingSchedules" type="List"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="isSearchButtonVisible" type="Boolean" default="false"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <lightning:notificationsLibrary aura:id="notifLib"/>
    
    <aura:if isTrue="{!v.isLoading}">
        <lightning:spinner aura:id="spinner" alternativeText="Loading" size="medium" />      
    </aura:if>
    
    <aura:if isTrue="{!v.isSearchButtonVisible}">
        <article class="slds-card">
            <div class="slds-card__body">
                <div class="slds-box slds-theme_default">
                    <lightning:layoutItem size="5">
                        <lightning:input aura:id="searchID" type="text" name="searchKey" label="Serial Number" 
                                         value="{!v.searchKey}" placeholder="Please enter serial number" style="width: 219px;"/>
                        <br/>
                        <lightning:button variant="brand" label="Search" onclick="{!c.handleClick}" />
                        <lightning:button variant="brand" label="Print" onclick="{!c.handlePrint}" />                    
                    </lightning:layoutItem>
                </div>
            </div>
        </article>
    </aura:if>
    
    <aura:if isTrue="{!v.recordExist}">
        
        <article class="slds-card">
            <div class="slds-card__body">
                <c:UnitInformationDetailCustom unitDetails = "{!v.unitDetails}"/>
            </div>
        </article>
        
        <c:CustomRelatedListComponent relatedListConfigName="CRL_Inventory_CampaignMember" ifPrintPage="false" dataList = "{!v.fieldAction}"/>
        <c:CustomRelatedListComponent relatedListConfigName="MobileWarrantyCoverage" ifPrintPage="false" dataList = "{!v.warrantyCoverage}"/>
        <c:CustomRelatedListComponent relatedListConfigName="CRL_UpcomingSchedules" ifPrintPage="false" dataList = "{!v.upComingSchedules}"/>
        <c:CustomRelatedListComponent relatedListConfigName="CRL_Inventory_MajorComponents" ifPrintPage="false" dataList = "{!v.majorCmp}"/>
        <c:CustomRelatedListComponent relatedListConfigName="ClaimMobile" ifPrintPage="false" dataList = "{!v.claims}"/>
    </aura:if>
    
</aura:component>