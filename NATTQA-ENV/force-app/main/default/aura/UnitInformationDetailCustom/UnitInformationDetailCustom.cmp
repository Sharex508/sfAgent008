<!-- created by LTI to display unit information data-->

<aura:component implements="flexipage:availableForRecordHome,forceCommunity:availableForAllPageTypes" access="global">
    
    <aura:attribute name="fieldListCol1" type="List"/>
    <aura:attribute name="fieldListCol2" type="List"/>
    <aura:attribute name="unitDetails" type="object"/>
    
    <div class="slds-is-relative slds-size_1-of-2 slds-max-small-size_1-of-1">
        <aura:if isTrue="{!v.isLoading}">
            <lightning:spinner aura:id="spinner" alternativeText="Loading" size="medium" />      
        </aura:if>
        
        <div class="slds-text-heading_medium">{!$Label.c.UnitInfoDetailObjectHeader}</div>
        
        <lightning:layout horizontalAlign="spread" multipleRows="true">
            
            <lightning:layoutItem padding="around-small" size="4" mediumDeviceSize="6" largeDeviceSize="4" flexibility="grow">
                <p class="slds-text-title"><lightning:formattedText value="Serial Number"/></p>
                <p><lightning:formattedText value="{!v.unitDetails.unitSerialNumber}"/></p>
                <br/>
                
                <p class="slds-text-title"><lightning:formattedText value="Model"/></p>
                <p><lightning:formattedText value="{!v.unitDetails.unitModelNumber}"/></p>
                <br/>
                
                <p class="slds-text-title"><lightning:formattedText value="Container/Trailer Number"/></p>
                <p><lightning:formattedText value="{!v.unitDetails.containerNumber}"/></p>
               
                <br/>
                <p class="slds-text-title"><lightning:formattedText value="OwnerName"/></p>
                <p><lightning:formattedText value="{!v.unitDetails.ownerName}"/></p><br/><br/>
            </lightning:layoutItem>
            
            
            <lightning:layoutItem padding="around-small" size="4" mediumDeviceSize="6" largeDeviceSize="4" flexibility="grow">
                <p class="slds-text-title"><lightning:formattedText value="VIN Number"/></p>
                <p><lightning:formattedText value="{!v.unitDetails.vinNumber}"/></p>
                <br/>
                
                <p class="slds-text-title"><lightning:formattedText value="Install Date"/></p>
                <p><lightning:formattedDateTime value="{!v.unitDetails.installDate}" year="numeric" month="numeric" day="numeric"/></p>
                <br/>
            </lightning:layoutItem>
            
        </lightning:layout>
        
    </div>
    
</aura:component>