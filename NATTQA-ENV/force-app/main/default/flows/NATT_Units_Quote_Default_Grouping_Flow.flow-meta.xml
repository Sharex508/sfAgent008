        <rules>
            <name>NATT_Units_Quote</name>
            <conditionLogic>(1 OR 2 OR 3 OR 4) AND (5 OR 6)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.NATT_Billing_Address__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Shipping_Address__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isBillingNull</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsShippingNull</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>NATT_Units_Quote</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NATT_Direct_Sales</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Address_Fields_from_NATT_Address</targetReference>
            </connector>
            <label>Natt Units Quote</label>
        </rules>
    </decisions>
    <description>Before Save Flow created to update &apos;Order by&apos; field on creation of NATT Units Quote for creating multiple Orders, update address fields on change natt address</description>
    <environments>Default</environments>
    <formulas>
        <name>BillingStreet</name>
        <dataType>String</dataType>
        <expression>LEFT ({!$Record.NATT_Billing_Address__r.NATT_Street__c} + &apos; &apos; + 
{!$Record.NATT_Billing_Address__r.NATT_Street_2__c} + &apos; &apos; + 
{!$Record.NATT_Billing_Address__r.NATT_Street_3__c} + &apos; &apos; + 
{!$Record.NATT_Billing_Address__r.NATT_Street_4__c},255)</expression>
    </formulas>
    <formulas>
        <name>isBillingNull</name>
        <dataType>Boolean</dataType>
        <expression>OR(ISBLANK({!$Record.SBQQ__BillingStreet__c}), 
 ISBLANK({!$Record.SBQQ__BillingCity__c}),
 ISBLANK({!$Record.SBQQ__BillingCountry__c}), 
ISBLANK({!$Record.SBQQ__BillingPostalCode__c}), 
ISBLANK({!$Record.SBQQ__BillingState__c}) )</expression>
    </formulas>
    <formulas>
        <name>IsShippingNull</name>
        <dataType>Boolean</dataType>
        <expression>OR(ISBLANK({!$Record.SBQQ__ShippingStreet__c}), 
 ISBLANK({!$Record.SBQQ__ShippingCity__c}),
 ISBLANK({!$Record.SBQQ__ShippingCountry__c}), 
ISBLANK({!$Record.SBQQ__ShippingPostalCode__c}), 
ISBLANK({!$Record.SBQQ__ShippingState__c}) )</expression>
    </formulas>
    <formulas>
        <name>NewquoteCheck</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>ShippingStreet</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Record.NATT_Shipping_Address__r.NATT_Street__c} + &apos; &apos; + 
{!$Record.NATT_Shipping_Address__r.NATT_Street_2__c} + &apos; &apos; + 
{!$Record.NATT_Shipping_Address__r.NATT_Street_3__c} + &apos; &apos; + 
{!$Record.NATT_Shipping_Address__r.NATT_Street_4__c},255)</expression>
    </formulas>
