        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Order_Record</name>
        <label>Update Order Record</label>
        <locationX>999</locationX>
        <locationY>443</locationY>
        <inputAssignments>
            <field>NATT_Billing_Address__c</field>
            <value>
                <elementReference>$Record.NATT_Opp_Billing_Address_Id__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATT_Market_Segment2__c</field>
            <value>
                <elementReference>$Record.SBQQ__Quote__r.CTBR_Market_Segment__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATT_Product_Family__c</field>
            <value>
                <elementReference>$Record.SBQQ__Quote__r.CTBR_Product_Family__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATT_Shipping_Address__c</field>
            <value>
