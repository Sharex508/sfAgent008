        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Activate_Order</name>
        <label>Activate Order</label>
        <locationX>185</locationX>
        <locationY>156</locationY>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Activated</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_CTBR_BluEdge_Order</name>
        <label>Update CTBR BluEdge Order</label>
        <locationX>522</locationX>
        <locationY>448</locationY>
        <inputAssignments>
            <field>NATT_Billing_Address__c</field>
            <value>
                <elementReference>$Record.NATT_Opp_Billing_Address_Id__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATT_Shipping_Address__c</field>
            <value>
                <elementReference>$Record.NATT_Opp_Shipping_Address_Id__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OrderedDate</field>
            <value>
