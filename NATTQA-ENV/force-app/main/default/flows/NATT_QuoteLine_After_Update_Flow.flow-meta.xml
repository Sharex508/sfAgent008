&quot;Requested Ship Date: &quot; &amp; TEXT({!$Record.NATT_Requested_Ship_Date__c}) &amp; &quot;\n&quot; &amp;
&quot;Quantity: &quot; &amp; TEXT({!$Record.SBQQ__Quantity__c})</expression>
