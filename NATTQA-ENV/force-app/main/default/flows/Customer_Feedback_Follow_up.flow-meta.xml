<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>Sends case creation email for the given case(s)</description>
        <name>Send_NPS_initial_Email</name>
        <label>Send NPS initial Email</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <actionName>NPSCaseEmailServiceInitial</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>caseIds</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>NPSCaseEmailServiceInitial</nameSegment>
    </actionCalls>
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <environments>Default</environments>
    <interviewLabel>Customer Feedback Follow up {!$Flow.CurrentDateTime}</interviewLabel>
