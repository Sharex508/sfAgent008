        </inputAssignments>
        <inputAssignments>
            <field>CONTAINER_LNBaan_Product_Number__c</field>
            <value>
                <elementReference>$Record.CONTAINER_Product_Number__c</elementReference>
            </value>
        </inputAssignments>
