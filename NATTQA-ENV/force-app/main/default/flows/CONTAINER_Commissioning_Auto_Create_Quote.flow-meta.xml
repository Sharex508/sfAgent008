    <description>Auto Create Commissioning record on quote status changed to APO Release.</description>
    <environments>Default</environments>
    <formulas>
        <name>AppendedValue</name>
        <dataType>String</dataType>
        <expression>TRIM(RIGHT({!OtherWarrantyCalculation},LEN({!OtherWarrantyCalculation})-1))</expression>
    </formulas>
    <formulas>
        <name>FinalValueCalculation</name>
        <dataType>String</dataType>
        <expression>TEXT(VALUE({!Loop_through_Quote_Line_Records.NATT_P_N__c}) * 12)</expression>
    </formulas>
    <formulas>
        <name>IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>JobStartDate</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <formulas>
        <name>OtherWarrantyCalculation</name>
        <dataType>String</dataType>
        <expression>CASE( TEXT({!OtherWarrantyCount}) , 
 &apos;1&apos;, TEXT({!OtherWarrantyCount})&amp; &apos;.&apos;&amp;{!Loop_through_Quote_Line_Records.CONTAINER_Warranty_Description__c}, 
 {!OtherWarrantyValue} &amp; &apos;, &apos;&amp; TEXT({!OtherWarrantyCount})&amp; &apos;.&apos;&amp;{!Loop_through_Quote_Line_Records.CONTAINER_Warranty_Description__c}
)</expression>
    </formulas>
    <formulas>
        <name>OtherWarrantyCountFormula</name>
        <dataType>Number</dataType>
        <expression>{!OtherWarrantyCount} + 1</expression>
        <scale>2</scale>
    </formulas>
