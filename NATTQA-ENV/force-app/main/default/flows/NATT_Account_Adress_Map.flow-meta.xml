<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Used to map NATT_Address_Physical__c and NATT_Address_Mailing__c city state zipcode country field to custom address fields to get google map feature</description>
    <environments>Default</environments>
    <interviewLabel>NATT Account Adress Map {!$Flow.CurrentDateTime}</interviewLabel>
    <label>NATT Account Adress Map</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>used to map the street, city, zip code , country value of NATT Physical and Mailing fields to Custom Address fields</description>
        <name>Update_NATT_Custom_Address</name>
        <label>Update NATT Custom Address</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>NATTMailing_Address__City__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Mailing__r.NATT_City__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTMailing_Address__CountryCode__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Mailing__r.NATT_Country__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTMailing_Address__PostalCode__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Mailing__r.NATT_Zip_Postal_Code__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTMailing_Address__StateCode__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Mailing__r.NATT_State_Province__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTMailing_Address__Street__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Mailing__r.NATT_Street__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTPhysical_Address__City__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Physical__r.NATT_City__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTPhysical_Address__CountryCode__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Physical__r.NATT_Country__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTPhysical_Address__PostalCode__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Physical__r.NATT_Zip_Postal_Code__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTPhysical_Address__StateCode__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Physical__r.NATT_State_Province__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>NATTPhysical_Address__Street__s</field>
            <value>
                <elementReference>$Record.NATT_Address_Physical__r.NATT_Street__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_NATT_Custom_Address</targetReference>
        </connector>
        <object>Account</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
