    <decisions>
        <name>Checking_Quote_Status</name>
        <label>Checking Quote Status</label>
        <locationX>660</locationX>
        <locationY>383</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>If_Status_is_PendingRSMAcceptance</name>
            <conditionLogic>1 AND (2 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.CONTAINER_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pending VP Approval</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>CONTAINER_GENSET_Quote</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>CONTAINER_NT_Quote</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Updating_Flag_on_RequestedShipDate_to_false</targetReference>
            </connector>
            <label>If Status is PendingRSMAcceptance</label>
        </rules>
        <rules>
            <name>If_Status_is_Pending_VP_Approval</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.CONTAINER_IS_TentativeProdSchd_Updated__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>False</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Updating_tentativeprodschd_flag_on_quote_to_false_after_rsm_acceptance</targetReference>
            </connector>
            <label>If Status is Pending VP Approval</label>
        </rules>
    </decisions>
