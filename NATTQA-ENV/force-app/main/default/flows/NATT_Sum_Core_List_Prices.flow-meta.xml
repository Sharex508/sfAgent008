<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>54.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>adds the core prices together</description>
        <name>Add_Up_Core_Prices</name>
        <label>Add Up Core Prices</label>
        <locationX>707</locationX>
        <locationY>471</locationY>
        <assignmentItems>
            <assignToReference>List_Price</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Core_Lines.SBQQ__OriginalPrice__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Core_Lines</targetReference>
        </connector>
    </assignments>
    <interviewLabel>NATT Sum Core List Prices {!$Flow.CurrentDateTime}</interviewLabel>
    <label>NATT Sum Core List Prices</label>
    <loops>
        <description>loop through the core quote lines to get the original prices</description>
        <name>Loop_Core_Lines</name>
        <label>Loop Core Lines</label>
        <locationX>539</locationX>
        <locationY>472</locationY>
        <collectionReference>CoreQuoteLines</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Up_Core_Prices</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_BlueEdge_Core_list_Price</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>get all the core quote lines that should add up</description>
        <name>All_Core_Quote_lines</name>
        <label>All Core Quote lines</label>
        <locationX>538</locationX>
        <locationY>353</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Core_Lines</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>NATT_Grouped_By_Line_Number__c</field>
            <operator>EqualTo</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>SBQQ__Quote__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.SBQQ__Quote__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>NATT_BluEdge_Price_Rollup__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Core</stringValue>
            </value>
        </filters>
        <object>SBQQ__QuoteLine__c</object>
        <outputReference>CoreQuoteLines</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>SBQQ__OriginalPrice__c</queriedFields>
        <queriedFields>NATT_BluEdge_Price_Rollup__c</queriedFields>
    </recordLookups>
    <recordUpdates>
        <description>updates the list price for core</description>
        <name>Update_BlueEdge_Core_list_Price</name>
        <label>Update BlueEdge Core list Price</label>
        <locationX>537</locationX>
        <locationY>621</locationY>
        <inputAssignments>
            <field>SBQQ__ListPrice__c</field>
            <value>
                <elementReference>List_Price</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>410</locationX>
        <locationY>47</locationY>
        <connector>
            <targetReference>All_Core_Quote_lines</targetReference>
        </connector>
        <filterLogic>2 AND (1 OR 3)</filterLogic>
        <filters>
            <field>NATT_Quote_Recordtype_Dev_Name__c</field>
            <operator>StartsWith</operator>
            <value>
                <stringValue>NATT_Units</stringValue>
            </value>
        </filters>
        <filters>
            <field>NATT_P_N__c</field>
            <operator>StartsWith</operator>
            <value>
                <stringValue>BLUEDGE-CORE</stringValue>
            </value>
        </filters>
        <filters>
            <field>NATT_Quote_Recordtype_Dev_Name__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>NATT_BluEdge</stringValue>
            </value>
        </filters>
        <object>SBQQ__QuoteLine__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>CoreQuoteLines</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>SBQQ__QuoteLine__c</objectType>
    </variables>
    <variables>
        <description>this gets assigned to the main core line</description>
        <name>List_Price</name>
        <dataType>Currency</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>2</scale>
        <value>
            <numberValue>0.0</numberValue>
        </value>
    </variables>
</Flow>
