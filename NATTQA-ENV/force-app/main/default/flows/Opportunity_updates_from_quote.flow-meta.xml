    <decisions>
        <description>if Quote Bill to and units ship to address is updated then other, then update the same address fields on opportunity for natt units Quote</description>
        <name>Is_Bill_To_and_Ship_To_Address_Updated</name>
        <label>Is Bill To and Ship To Address Updated</label>
        <locationX>446</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Quote_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Check_Bill_to_and_ship_to_address_updated</name>
            <conditionLogic>(1 AND ( 2 OR 3 )) OR  ((4 OR 5) AND 6)</conditionLogic>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Billing_Address__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.SBQQ__Opportunity2__r.NATT_Billing_Address__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Shipping_Address__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.SBQQ__Opportunity2__r.NATT_Shipping_Address__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Billing_Address__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Shipping_Address__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Billing_and_Shipping</targetReference>
            </connector>
            <label>Check Bill to and ship to address updated</label>
        </rules>
        <rules>
            <name>Is_Shipping_Address_Updated</name>
            <conditionLogic>(1 AND 2) OR 3</conditionLogic>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Shipping_Address__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.SBQQ__Opportunity2__r.NATT_Shipping_Address__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Shipping_Address__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Shipping_Address</targetReference>
            </connector>
            <label>Is Shipping Address Updated</label>
        </rules>
        <rules>
            <name>Is_Billing_Address_Changed</name>
            <conditionLogic>(1 AND 2) OR 3</conditionLogic>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Billing_Address__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.SBQQ__Opportunity2__r.NATT_Billing_Address__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.NATT_Billing_Address__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Billing_Address</targetReference>
            </connector>
            <label>Is Billing Address Changed</label>
        </rules>
    </decisions>
    <decisions>
