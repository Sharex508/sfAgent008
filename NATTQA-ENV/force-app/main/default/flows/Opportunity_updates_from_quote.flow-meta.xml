        <rules>
            <name>Outcome_1_of_Quote_Fully_Approved</name>
            <conditionLogic>1 AND 2 AND (3 OR (4 AND 5))</conditionLogic>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
