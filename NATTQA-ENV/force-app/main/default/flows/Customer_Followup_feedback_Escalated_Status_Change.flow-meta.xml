<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>NPSCaseEscalatedOnStatusChange</name>
        <label>NPSCaseEscalatedOnStatusChange</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>NPSCaseEmailServiceEscalated</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>caseIds</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>NPSCaseEmailServiceEscalated</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>This flow is triggered when the case status is changed to escalated.</description>
    <environments>Default</environments>
    <interviewLabel>Customer Followup feedback Escalated Status Change {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Customer Followup feedback Escalated Status Change</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>NPSCaseEscalatedOnStatusChange</targetReference>
        </connector>
        <filterFormula>AND(
    ISPICKVAL({!$Record.Origin}, &quot;NPS process – Qualtrics&quot;),
    {!$Record.RecordType.DeveloperName} = &quot;Customer_Survey_Index&quot;,
    AND(ISPICKVAL({!$Record.Status}, &quot;Escalated&quot;),ISCHANGED({!$Record.Status}))
)</filterFormula>
        <object>Case</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
