        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>&lt;p&gt;Hi &lt;strong&gt;{!$Record.Container_Commissioning_Contact__r.FirstName} {!$Record.Container_Commissioning_Contact__r.LastName},&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;You have received a new Commissioning Order having following Details-&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Commissioning Name &lt;/strong&gt;: {!CommissioningRecName}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Model Number &lt;/strong&gt; : {!$Record.CONTAINER_Model_Number__c}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;PID&lt;/strong&gt; : &lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;{!$Record.CONTAINER_PID_Number__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Job Number &lt;/strong&gt;: {!$Record.CONTAINER_Commissioning_Record_Name__c}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Job Start Date &lt;/strong&gt;: {!$Record.CONTAINER_Job_Start_Date__c}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Job Quantity &lt;/strong&gt;: {!$Record.CONTAINER_Job_Quantity__c}&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;background-color: var(--lwc-colorBackgroundInput,rgb(255, 255, 255));&quot;&gt;Commissioning&lt;/strong&gt;&lt;strong&gt; Rate &lt;/strong&gt;: {!$Record.CONTAINER_Commisioning_Rate__c}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Total Price &lt;/strong&gt;: {!$Record.CONTAINER_Total_Price__c}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;You can acknowledge the &lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;Commissioning Order by clicking on the following link-&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;{!recordURL}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;{!CommissioningRecName}&lt;/a&gt;&lt;/p&gt;</text>
