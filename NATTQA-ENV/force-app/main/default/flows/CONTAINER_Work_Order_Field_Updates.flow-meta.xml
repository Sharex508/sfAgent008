{!$Record.CONTAINER_Commissioning__r.CONTAINER_Commissioning__r.Name}&amp;&apos;_&apos;&amp;TEXT({!$Record.CONTAINER_AWO_Number__c})&amp;&apos;AO&apos;&amp; {!$Record.CONTAINER_Commissioning__r.CONTAINER_Commisioning_Agent__r.AccountNumber}&amp;&apos;_&apos;&amp; {!ParentAccountName},
