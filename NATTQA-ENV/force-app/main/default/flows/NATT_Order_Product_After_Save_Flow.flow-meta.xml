    <formulas>
        <name>Comment_for_CSR_Task</name>
        <dataType>String</dataType>
        <expression>{!$Record.OrderItemNumber}&amp;&quot; - Requested Ship Date was changed from &quot; &amp; TEXT({!$Record__Prior.NATT_Requested_Ship_Date__c}) &amp; &quot; to &quot; &amp; TEXT({!$Record.NATT_Requested_Ship_Date__c}) &amp; &quot;.&quot;</expression>
    </formulas>
    <formulas>
        <name>IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>Subject_for_CSR_Task</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.Order.NATT_Product_Family__c})&amp;&quot; - Requested Ship Date Change Review&quot;</expression>
    </formulas>
    <formulas>
        <name>TaskDueDate</name>
        <dataType>Date</dataType>
        <expression>TODAY()+3</expression>
    </formulas>
    <formulas>
        <name>UpdateChangelogHistoryField</name>
        <dataType>String</dataType>
        <expression>&apos;&lt;br/&gt;&lt;b&gt;NATT Field: Requested Ship Date&lt;/b&gt;&lt;br/&gt;Original Value:&apos;+TEXT ({!$Record__Prior.NATT_Requested_Ship_Date__c})+&apos;&lt;br/&gt;New Value:&apos;+TEXT ({!$Record.NATT_Requested_Ship_Date__c})</expression>
    </formulas>
