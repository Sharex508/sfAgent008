    <formulas>
        <name>BluEdgeIdFormula</name>
        <dataType>String</dataType>
        <expression>TEXT(YEAR(DATEVALUE({!$Record.CreatedDate}))) &amp; 
IF(LEN(TEXT(MONTH(DATEVALUE({!$Record.CreatedDate}))))=1,&quot;0&quot;,NULL) &amp;
TEXT(MONTH(DATEVALUE({!$Record.CreatedDate}))) &amp; {!$Record.Name}</expression>
    </formulas>
    <formulas>
        <name>frmUnitDiscountChanged</name>
        <dataType>Boolean</dataType>
        <expression>IF(AND({!$Record__Prior.NATT_Total_Discount2__c} != {!$Record.NATT_Total_Discount2__c}, NOT(ISNEW())), true, false)</expression>
    </formulas>
    <formulas>
        <name>IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <description>calculates the reminder for the csr task</description>
        <name>ReminderDate</name>
        <dataType>DateTime</dataType>
        <expression>NOW()+5</expression>
    </formulas>
    <formulas>
        <description>used in the task that gets created for the CSR</description>
        <name>Subject_For_CSR_Task</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.NATT_Product_Family__c})&amp;&quot; - Add a Product Number and/or Paint Code to Quote&quot;</expression>
    </formulas>
    <formulas>
        <name>TaskDueDate</name>
