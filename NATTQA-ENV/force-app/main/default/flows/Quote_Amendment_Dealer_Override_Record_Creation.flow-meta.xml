    <decisions>
        <name>Dealer_Override_records_exist</name>
        <label>Dealer Override records exist on Original Quote?</label>
        <locationX>418</locationX>
        <locationY>647</locationY>
        <defaultConnectorLabel>No Records Exist</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Dealer_Override_Records</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_through_Dealer_Override_records</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Dealer_Override_records_exist_on_Amended_Quote</name>
        <label>Dealer Override records exist on Amended Quote?</label>
        <locationX>176</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Get_Dealer_Override_Records</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Records. Create new</defaultConnectorLabel>
        <rules>
            <name>Yes1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Dealer_Override_Records_fromnewquote</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>Yes records already exist</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Quote - Amendment - Dealer Override Record Creation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Quote - Amendment - Dealer Override Record Creation</label>
    <loops>
