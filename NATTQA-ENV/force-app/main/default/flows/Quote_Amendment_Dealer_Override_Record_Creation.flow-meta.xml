        <label>Loop through Dealer Override records</label>
        <locationX>286</locationX>
        <locationY>755</locationY>
        <collectionReference>Get_Dealer_Override_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Clone_Dealer_Override_record</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Create_cloned_Records</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
