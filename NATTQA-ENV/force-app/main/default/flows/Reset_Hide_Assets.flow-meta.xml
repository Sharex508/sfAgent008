        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <waits>
        <name>Pause_for_1_minutes</name>
        <label>Pause for 1 minutes</label>
        <locationX>176</locationX>
        <locationY>244</locationY>
        <defaultConnectorLabel>Default Path</defaultConnectorLabel>
        <waitEvents>
            <name>X1_Minutes_Delay</name>
            <conditionLogic>and</conditionLogic>
            <connector>
                <targetReference>Get_All_Hidden_Assets</targetReference>
            </connector>
            <eventType>AlarmEvent</eventType>
            <inputParameters>
                <name>AlarmTime</name>
                <value>
                    <elementReference>frmTimeDelay</elementReference>
                </value>
            </inputParameters>
            <inputParameters>
                <name>TimeOffset</name>
                <value>
                    <numberValue>0.0</numberValue>
                </value>
