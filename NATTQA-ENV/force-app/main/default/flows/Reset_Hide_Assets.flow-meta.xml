    <environments>Default</environments>
    <formulas>
        <name>frmTimeDelay</name>
        <dataType>DateTime</dataType>
        <expression>{!$Flow.CurrentDateTime} + 0.0001</expression>
    </formulas>
    <formulas>
        <name>frmUsageEndDate</name>
        <dataType>Date</dataType>
        <expression>IF({!Iterate_over_each_asset.CustomUsageEndDate__c}, null, {!Iterate_over_each_asset.UsageEndDate})</expression>
    </formulas>
    <interviewLabel>Reset Hide Assets {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Reset Hide Assets</label>
    <loops>
        <name>Iterate_over_each_asset</name>
        <label>Iterate over each asset</label>
        <locationX>786</locationX>
        <locationY>245</locationY>
        <collectionReference>Get_All_Hidden_Assets</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Reset_Hidden_and_Hidden_By</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Assets</targetReference>
        </noMoreValuesConnector>
