            <operator>Assign</operator>
            <value>
                <elementReference>frmUsageEndDate</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Iterate_over_each_asset.CustomUsageEndDate__c</assignToReference>
