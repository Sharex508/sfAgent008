<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CONTAINER_QtyShippedExceed_JobQty_Update</fullName>
    <active>true</active>
    <description>CONTAINER QtyShipped Exceed JobQty on Update</description>
    <errorConditionFormula>AND(
NOT( $Permission.CONTAINER_Bypass_Validation_Rule ),
ISCHANGED(CONTAINER_Quantity_Shipped__c ), 
(CONTAINER_Commissioning__r.CONTAINER_Quantity_Shipped__c  + CONTAINER_Quantity_Shipped__c -  PRIORVALUE(CONTAINER_Quantity_Shipped__c)) &gt;  CONTAINER_Commissioning__r.CONTAINER_Job_Quantity__c 
)</errorConditionFormula>
    <errorMessage>Commissioning quantity shipped value cannot exceed  commissioning job quantity.</errorMessage>
</ValidationRule>
