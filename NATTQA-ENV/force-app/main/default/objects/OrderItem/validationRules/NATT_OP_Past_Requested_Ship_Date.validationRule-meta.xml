<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_OP_Past_Requested_Ship_Date</fullName>
    <active>false</active>
    <description>prevents the user from entering a past date on the Requested Ship Date</description>
    <errorConditionFormula>AND(
BEGINS(NATT_Order_Record_Type_Developer_Name__c,&quot;NATT_Units&quot;),
NATT_Requested_Ship_Date__c&lt;TODAY(),
OR(ISNEW(),ISCHANGED(NATT_Requested_Ship_Date__c))
)</errorConditionFormula>
    <errorMessage>Past dates are not allowed</errorMessage>
</ValidationRule>
