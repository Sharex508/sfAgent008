<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CONTAINER_UpdateChildComm_JobQty_Exceed</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
NOT($Permission.CONTAINER_Bypass_Validation_Rule ),
ISCHANGED( CONTAINER_Job_Quantity__c ),
CONTAINER_Job_Quantity__c &gt; PRIORVALUE(CONTAINER_Job_Quantity__c),
(CONTAINER_Job_Quantity__c - PRIORVALUE(CONTAINER_Job_Quantity__c))&gt;CONTAINER_Commissioning__r.CONTAINER_Job_Quantity__c
)</errorConditionFormula>
    <errorMessage>Child commissioning job quantity cannot exceed parent commissioning total job quantity.</errorMessage>
</ValidationRule>
