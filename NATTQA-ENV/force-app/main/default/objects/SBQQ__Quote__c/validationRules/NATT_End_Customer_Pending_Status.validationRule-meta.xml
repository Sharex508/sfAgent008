<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_End_Customer_Pending_Status</fullName>
    <active>true</active>
    <description>CSR should not be able to add Product Number</description>
    <errorConditionFormula>AND(
BEGINS($RecordType.DeveloperName,&quot;NATT_Units_Quote&quot;),
NOT(ISBLANK(NATT_End_Customer__c)),
NOT(ISPICKVAL(NATT_End_Customer__r.NATT_Status__c, &quot;Active&quot;)),
ISCHANGED(NATT_Configured_Unit_Code__c)
)</errorConditionFormula>
    <errorDisplayField>NATT_Configured_Unit_Code__c</errorDisplayField>
    <errorMessage>End Customer status is pending</errorMessage>
</ValidationRule>
