<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_Order_Add_Product_Number</fullName>
    <active>false</active>
    <description>Primary Quote needs to have product number to be ordered</description>
    <errorConditionFormula>AND(
  BEGINS($RecordType.DeveloperName,&quot;NATT_Units_Quote&quot;),
  ISPICKVAL(SBQQ__Type__c,&quot;Quote&quot;),
  ISBLANK(NATT_Purchase_Order__c),
  NOT(ISBLANK(NATT_Configured_Unit_Code__c))
)</errorConditionFormula>
    <errorDisplayField>NATT_Configured_Unit_Code__c</errorDisplayField>
    <errorMessage>The quote must have a Purchase Order # in order to enter a Product Number</errorMessage>
</ValidationRule>
