<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_CustomerAddressValidation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NATT_Quote_Record_Type_Developer_Name__c = &apos;NATT_eSolutions&apos;,
NOT(ISBLANK(NATT_Customer_Contact__c)),
OR(ISBLANK(NATT_Customer_Contact__r.MailingCity),
ISBLANK(NATT_Customer_Contact__r.MailingCountry),
ISBLANK(NATT_Customer_Contact__r.MailingState),
ISBLANK(NATT_Customer_Contact__r.MailingStreet),
ISBLANK(NATT_Customer_Contact__r.MailingPostalCode)
))</errorConditionFormula>
    <errorMessage>Customer mailing address is required (Street, City, State/Province, Zip/Postal Code, Country).
Please update the customer contact record with a valid mailing address.</errorMessage>
</ValidationRule>
