<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_CustomerEmailCannotBeNull</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NATT_Quote_Record_Type_Developer_Name__c = &apos;NATT_eSolutions&apos;,
NOT(ISBLANK(NATT_Customer_Contact__c)),
NATT_Customer_Contact__r.Email = &apos;&apos;)</errorConditionFormula>
    <errorDisplayField>NATT_Customer_Contact__c</errorDisplayField>
    <errorMessage>Customer Email is required. Please update the customer contact record with a valid email address.</errorMessage>
</ValidationRule>
