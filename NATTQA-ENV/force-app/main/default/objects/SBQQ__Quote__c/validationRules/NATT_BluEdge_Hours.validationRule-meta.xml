<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_BluEdge_Hours</fullName>
    <active>true</active>
    <description>Optional Coverage Hours must be less than or equal to Major Component Hours</description>
    <errorConditionFormula>AND(NATT_Quote_Record_Type_Developer_Name__c = &apos;NATT_BluEdge&apos;, VALUE(TEXT(NATT_Optional_Coverage_Hours__c)) &gt;  VALUE(TEXT(NATT_Major_Component_Hours__c)), NOT(ISNULL(VALUE(TEXT(NATT_Optional_Coverage_Hours__c)))), NOT(ISNULL(VALUE(TEXT(NATT_Major_Component_Hours__c)))))</errorConditionFormula>
    <errorMessage>Optional Coverage Hours must be less than or equal to Major Component Hours</errorMessage>
</ValidationRule>
