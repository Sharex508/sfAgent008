<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Customer_Name_25_Characters_Only</fullName>
    <active>false</active>
    <errorConditionFormula>AND(RecordType.Name = &apos;Customer&apos;,
    LEN(Name) &gt; 25)</errorConditionFormula>
    <errorDisplayField>NATT_24_Hour_Service__c</errorDisplayField>
    <errorMessage>Customer Name should be less than 25 characters only</errorMessage>
</ValidationRule>
