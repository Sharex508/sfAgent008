<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_Cannot_Modify_DS_or_Internal_Name</fullName>
    <active>true</active>
    <description>prevent users from editing the direct sale or internal account name.</description>
    <errorConditionFormula>And($Permission.NATT_Bypass_Direct_Sale_Account_Name = false,
ISCHANGED(Name),
OR(RecordType.DeveloperName = &quot;NATT_OEM&quot;,RecordType.DeveloperName = &quot;Internal&quot;)
)</errorConditionFormula>
    <errorDisplayField>Name</errorDisplayField>
    <errorMessage>You don&apos;t have permission to modify this Account Name</errorMessage>
</ValidationRule>
