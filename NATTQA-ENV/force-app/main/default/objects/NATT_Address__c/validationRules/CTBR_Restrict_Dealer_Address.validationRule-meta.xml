<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CTBR_Restrict_Dealer_Address</fullName>
    <active>true</active>
    <description>Prevents CTBR Users from modifying Dealer Address</description>
    <errorConditionFormula>AND(NATT_Account__r.RecordType.DeveloperName = &quot;CTBR_Dealer&quot;,
$Profile.Name = &quot;CTBR General Manager&quot;
)</errorConditionFormula>
    <errorMessage>You may not create or modify a Dealer Address</errorMessage>
</ValidationRule>
