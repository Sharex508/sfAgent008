<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_CannotChangeRSDonExistingLines</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NOT(ISBLANK(SBQQ__UpgradedAsset__c)),
ISCHANGED(NATT_Requested_Ship_Date__c),
NATT_Requested_Ship_Date__c &lt;&gt; SBQQ__UpgradedAsset__r.NATT_Requested_Ship_Date__c,
NATT_Is_Base_Unit__c,
BEGINS(SBQQ__Quote__r.NATT_Quote_Record_Type_Developer_Name__c, &apos;NATT_Units&apos;) 
)</errorConditionFormula>
    <errorMessage>You may not change the requested ship date on existing line.</errorMessage>
</ValidationRule>
