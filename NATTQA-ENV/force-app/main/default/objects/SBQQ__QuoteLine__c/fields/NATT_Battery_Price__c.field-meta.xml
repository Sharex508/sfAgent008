<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_Battery_Price__c</fullName>
    <description>Used to calculate the price of the replacement battery for CRMA</description>
    <formula>IF(ISPICKVAL(NATT_Battery_Type__c, &quot;Excluded&quot;),0,IF(ISPICKVAL(NATT_Battery_Type__c,&quot;AGM&quot;), 426.62, 171.81))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>zDeleteBattery Price</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
