<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_Engine_Hours_Blank</fullName>
    <active>true</active>
    <description>For Type field if Engine Authorization Request value is selected. Engine Hours cannot be blank.</description>
    <errorConditionFormula>AND(ISPICKVAL(Type, &quot;Engine Authorization Request&quot;), ISBLANK(NATT_Engine_Hours__c),
BEGINS($RecordType.DeveloperName,&quot;NATT_&quot;))</errorConditionFormula>
    <errorDisplayField>NATT_Engine_Hours__c</errorDisplayField>
    <errorMessage>Enter number in the Engine Hours Field</errorMessage>
</ValidationRule>
