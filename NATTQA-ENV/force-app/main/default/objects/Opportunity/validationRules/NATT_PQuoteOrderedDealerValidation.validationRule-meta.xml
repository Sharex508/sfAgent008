<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_PQuoteOrderedDealerValidation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(TEXT(SBQQ__PrimaryQuote__r.SBQQ__Status__c) = &apos;Ordered&apos;, BEGINS(SBQQ__PrimaryQuote__r.NATT_Quote_Record_Type_Developer_Name__c, &apos;NATT_BluEdge&apos;), TEXT($User.UserType) &lt;&gt; &apos;Standard&apos;)</errorConditionFormula>
    <errorMessage>The primary quote was already ordered. If you need to edit it, contact your admin.</errorMessage>
</ValidationRule>
