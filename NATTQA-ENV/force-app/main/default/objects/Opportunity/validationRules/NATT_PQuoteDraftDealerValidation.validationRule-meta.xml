<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>NATT_PQuoteDraftDealerValidation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(TEXT(SBQQ__PrimaryQuote__r.SBQQ__Status__c) = &apos;Draft&apos;,
OR(BEGINS(SBQQ__PrimaryQuote__r.NATT_Quote_Record_Type_Developer_Name__c, &apos;NATT_Units&apos;), BEGINS(SBQQ__PrimaryQuote__r.NATT_Quote_Record_Type_Developer_Name__c, &apos;NATT_BluEdge&apos;)),
TEXT($User.UserType) &lt;&gt; &apos;Standard&apos;,
OR(TEXT(StageName) = &apos;Closing&apos;, TEXT(StageName) = &apos;Closed Won&apos;),
ISCHANGED(StageName))</errorConditionFormula>
    <errorMessage>You may not update the Stage to Closing/Closed Won.</errorMessage>
</ValidationRule>
