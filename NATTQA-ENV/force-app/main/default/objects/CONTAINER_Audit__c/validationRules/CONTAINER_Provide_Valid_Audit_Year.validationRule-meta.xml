<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CONTAINER_Provide_Valid_Audit_Year</fullName>
    <active>true</active>
    <description>Validation to populate valid audit year.</description>
    <errorConditionFormula>AND(
NOT($Permission.CONTAINER_Bypass_Validation_Rule),
OR(Not(ISNUMBER(CONTAINER_Audit_Year__c)),
LEN(CONTAINER_Audit_Year__c ) &lt;&gt; 4),
NOT(ISBLANK(CONTAINER_Audit_Year__c))
)</errorConditionFormula>
    <errorDisplayField>CONTAINER_Audit_Year__c</errorDisplayField>
    <errorMessage>Please enter a valid Year.</errorMessage>
</ValidationRule>
