<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>NATT_Account_Name__c</field>
        <field>NATT_End_Customer_Name__c</field>
        <field>NATT_Total_Discount__c</field>
        <field>NATT_Total_Discount2__c</field>
        <field>SBQQ__NetAmount__c</field>
        <field>Owner</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>alanrodrigo.romero@carrier.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>AND(Owner:User.CTM_Dealer_Region_1__c,  SBQQ__AverageCustomerDiscount__c &gt;= 0 )</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Regional Manager for Region 1</label>
        <name>Regional_Manager_for_Region_1</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>javier.calixtomarcos@carrier.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>AND(Owner:User.CTM_Dealer_Region_2__c,  SBQQ__AverageCustomerDiscount__c &gt;= 0 )</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Regional Manager for Region 2</label>
        <name>Regional_Manager_for_Region_2</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>jesus.lopez1@carrier.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>AND(Owner:User.CTM_Dealer_Region_3__c,  SBQQ__AverageCustomerDiscount__c &gt;= 0 )</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Regional Manager for Region 3</label>
        <name>Regional_Manager_for_Region_3</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>viviana.avila@carrier.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Sales Manager</label>
        <name>Sales_Manager</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>alejandro.genera@carrier.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>General Manager</label>
        <name>General_Manager</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>alfonso.ortiz@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Finance Manager</label>
        <name>Finance_Manager</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>CTM Discounting Only Approval Process</description>
    <emailTemplate>unfiled$public/CTM_Pending_for_Approval</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND 2 AND 3 AND 4</booleanFilter>
        <criteriaItems>
            <field>SBQQ__Quote__c.NATT_Quote_Record_Type_Developer_Name__c</field>
            <operation>equals</operation>
            <value>MX_Units_Quote</value>
        </criteriaItems>
        <criteriaItems>
            <field>SBQQ__Quote__c.SBQQ__Status__c</field>
            <operation>equals</operation>
            <value>Rejected,Draft</value>
        </criteriaItems>
        <criteriaItems>
            <field>SBQQ__Quote__c.CTM_Quote_contains_Non_Stock_Item__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <criteriaItems>
            <field>SBQQ__Quote__c.SBQQ__PaymentTerms__c</field>
            <operation>equals</operation>
            <value>Net 60</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>NATT_Final_Approval_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Send_Email_Notification_that_Quote_has_been_approved</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Set_CTM_Units_Approved_RT</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Send_Email_Notification_that_Quote_has_been_rejected</name>
            <type>Alert</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_Quote_Request_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Pending_Approval</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>CTM Discounting Only Approval Process</label>
    <processOrder>8</processOrder>
    <recallActions>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Draft</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Set_CTM_Units_RT</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
