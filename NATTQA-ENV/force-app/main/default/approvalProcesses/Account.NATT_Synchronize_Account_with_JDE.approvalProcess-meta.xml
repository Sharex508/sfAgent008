<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>RecordType</field>
        <field>Type</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NATT_AR_Manager__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Do manual steps for JDE and Salesforce</label>
        <name>Do_manual_steps_for_JDE_and_Salesforce</name>
    </approvalStep>
    <emailTemplate>unfiled$public/NATT_New_Account_Template</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <finalApprovalActions>
        <action>
            <name>NATT_Account_Creation_Approved_Notification</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Set_JDE_Update_field_to_Completed</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_Account_Creation_Rejected_Notification</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Set_JDE_Update_field_to_None</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Set_Send_for_Approval_field_false</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_New_Account_Creation_Notification</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Set_JDE_Update_field_to_Pending</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Synchronize Account with JDE</label>
    <postTemplate>NATT_New_Account_Post_Template</postTemplate>
    <processOrder>1</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
