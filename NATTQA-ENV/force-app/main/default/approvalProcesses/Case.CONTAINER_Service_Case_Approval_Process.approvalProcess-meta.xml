<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>creator</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>NATT_Date_of_Entry__c</field>
        <field>CaseNumber</field>
        <field>Status</field>
        <field>Owner</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>CONTAINER_Case_Approval_Queue</name>
                <type>queue</type>
            </approver>
            <approver>
                <name>CONTAINER_RSM_NAO</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <description>Sending Approval request to RSM NAO group users.</description>
        <entryCriteria>
            <criteriaItems>
                <field>Case.CONTAINER_Region__c</field>
                <operation>contains</operation>
                <value>NAO</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Approval Request from NAO</label>
        <name>CONTAINER_Approval_Request_from_NAO</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>CONTAINER_Case_Approval_Queue</name>
                <type>queue</type>
            </approver>
            <approver>
                <name>CONTAINER_RSM_APO</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <description>Sending Approval request to RSM APO group users.</description>
        <entryCriteria>
            <criteriaItems>
                <field>Case.CONTAINER_Region__c</field>
                <operation>contains</operation>
                <value>APO</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Approval Request from APO</label>
        <name>Approval_Request_from_APO</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>CONTAINER_Case_Approval_Queue</name>
                <type>queue</type>
            </approver>
            <approver>
                <name>CONTAINER_RSM_EMEA</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <description>Sending Approval request to RSM EMEA group users.</description>
        <entryCriteria>
            <criteriaItems>
                <field>Case.CONTAINER_Region__c</field>
                <operation>contains</operation>
                <value>EMEA</value>
            </criteriaItems>
        </entryCriteria>
        <label>Approval Request from EMEA</label>
        <name>Approval_Request_from_EMEA</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>Approval Process for Container Service Case object.</description>
    <emailTemplate>unfiled$public/CONTAINER_Service_Case_Approval_Template</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Case.Type</field>
            <operation>equals</operation>
            <value>Training Request</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.CONTAINER_Region__c</field>
            <operation>equals</operation>
            <value>EMEA,NAO,APO</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.RecordType</field>
            <operation>equals</operation>
            <value>CONTAINER Service Engineering</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>CONTAINER_Send_Approved_Case_alert_to_users</name>
            <type>Alert</type>
        </action>
        <action>
            <name>CONTAINER_Update_Case_to_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>CONTAINER_Send_Rejected_Case_alert_to_users</name>
            <type>Alert</type>
        </action>
        <action>
            <name>CONTAINER_Update_Case_to_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>CONTAINER_Update_Case_to_Pending</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>CONTAINER Service Case Approval Process</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
