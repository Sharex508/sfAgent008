<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>SBQQ__Account__c</field>
        <field>NATT_End_Customer_Company__c</field>
        <field>Name</field>
        <field>Owner</field>
        <field>NATT_Total_Order_Net_Amount__c</field>
        <field>NATT_Total_Discount__c</field>
        <field>NATT_Quote_Special_Options__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_1__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1 OR 2</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.RecordType</field>
                <operation>equals</operation>
                <value>NATT Direct Sales</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.RecordType</field>
                <operation>equals</operation>
                <value>NATT Direct Sales Quote Amendment</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>NFM Approval</label>
        <name>NFM_Approval</name>
        <rejectionActions>
            <action>
                <name>NATT_Approver_1_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_2_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_2_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_2__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Quote_Record_Type_Developer_Name__c</field>
                <operation>startsWith</operation>
                <value>NATT_Direct_Sales</value>
            </criteriaItems>
        </entryCriteria>
        <label>Sales Ops Approval</label>
        <name>Sales_Ops_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_2_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>Updated so discounts consider a group of orders + the quote being approved V4 + Added approval step for BluEdge team</description>
    <emailTemplate>unfiled$public/NATT_Discount_approval_notification</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>AND(
  BEGINS(RecordType.DeveloperName,&quot;NATT_Direct_Sales&quot;),
  OR(
    ISPICKVAL(SBQQ__Status__c,&apos;Draft&apos;),
    NOT(ISPICKVAL(SBQQ__Status__c,&apos;Direct Sales - Auto Approved&apos;)),
    ISPICKVAL(SBQQ__Status__c,&apos;Rejected&apos;)
  ),
  OR(
    AND(
      NATT_Latest_Requested_Ship_Date__c &gt;= TODAY(),
      ISPICKVAL(SBQQ__Type__c,&apos;Quote&apos;)
    ),
    ISPICKVAL(SBQQ__Type__c,&apos;Amendment&apos;)
  )
)</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>NATT_Direct_Sales_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_Quote_Request_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Pending_Approval</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Approval_Submission_Notification</name>
            <type>Alert</type>
        </action>
    </initialSubmissionActions>
    <label>NATT Direct Sales Approval</label>
    <processOrder>18</processOrder>
    <recallActions>
        <action>
            <name>NATT_Approver_1_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_2_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Draft</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
