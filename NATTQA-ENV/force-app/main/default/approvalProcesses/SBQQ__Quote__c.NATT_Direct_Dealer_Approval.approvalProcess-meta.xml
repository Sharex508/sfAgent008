<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>SBQQ__Account__c</field>
        <field>NATT_End_Customer_Company__c</field>
        <field>Name</field>
        <field>Owner</field>
        <field>NATT_Total_Order_Net_Amount__c</field>
        <field>NATT_Total_Discount__c</field>
        <field>NATT_Quote_Special_Options__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_1__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.RecordType</field>
                <operation>equals</operation>
                <value>NATT Direct Sales</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>NFM Approval</label>
        <name>NFM_Approval</name>
        <rejectionActions>
            <action>
                <name>NATT_Approver_1_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_2_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_2_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_2__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Quote_Record_Type_Developer_Name__c</field>
                <operation>startsWith</operation>
                <value>NATT_Direct_Sales</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>National Fleet Manager Approval</label>
        <name>National_Fleet_Manager_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_2_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_3__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>((1 OR 2) AND 3) OR (4  AND (5 OR 6)) OR ((7 OR 8) AND 9)</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>5</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 100,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Diesel Truck,Direct Drive</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Trailer,Solara</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>15</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 200,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>5</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 100,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>APU</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Region Director Approval</label>
        <name>Region_Director_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_4__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>((1 OR 2) AND 3) OR ((4 OR 5) AND 6) OR ((7 OR 8) AND 9)</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>10</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 250,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Diesel Truck,Direct Drive</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>35</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 500,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Trailer,Solara</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>10</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 250,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>APU</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Director of Sales Approval</label>
        <name>Director_of_Sales_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_6__c</name>
                <type>relatedUserField</type>
            </approver>
            <approver>
                <name>NATT_Approver_5__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>((1 OR 2) AND 3) OR ((4 OR 5) AND 6) OR ((7 OR 8) AND 9)</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>20</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 1,000,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Diesel Truck,Direct Drive</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>45</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 5,000,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Trailer,Solara</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>20</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Order_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 1,000,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>APU</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>VP or CFO Approval</label>
        <name>VP_or_CFO_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>christopher.comeaux@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>jesse.siebentritt@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>stuart.m.johnson@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Discounted_BluEdge__c</field>
                <operation>equals</operation>
                <value>True</value>
            </criteriaItems>
        </entryCriteria>
        <label>BluEdge Team</label>
        <name>BluEdge_Team</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>Updated so discounts consider a group of orders + the quote being approved V4 + Added approval step for BluEdge team</description>
    <emailTemplate>unfiled$public/NATT_Discount_approval_notification</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>AND(BEGINS(RecordType.DeveloperName,&quot;NATT_Direct_Sales&quot;),
OR(ISPICKVAL(SBQQ__Status__c,&apos;Draft&apos;),
ISPICKVAL(SBQQ__Status__c,&apos;Rejected&apos;)),
OR(AND(NATT_Latest_Requested_Ship_Date__c &gt;= TODAY(), ISPICKVAL(SBQQ__Type__c,&apos;Quote&apos;)),
ISPICKVAL(SBQQ__Type__c,&apos;Amendment&apos;)))</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>NATT_Final_Approval_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_Quote_Request_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Pending_Approval</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Approval_Submission_Notification</name>
            <type>Alert</type>
        </action>
    </initialSubmissionActions>
    <label>NATT Direct Dealer Approval</label>
    <processOrder>15</processOrder>
    <recallActions>
        <action>
            <name>NATT_Approver_1_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_2_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Draft</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
