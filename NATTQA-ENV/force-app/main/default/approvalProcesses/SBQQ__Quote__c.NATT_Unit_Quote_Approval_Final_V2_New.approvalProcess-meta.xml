<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>SBQQ__Account__c</field>
        <field>NATT_End_Customer_Company__c</field>
        <field>Name</field>
        <field>Owner</field>
        <field>NATT_Total_Order_Net_Amount__c</field>
        <field>NATT_Total_Discount__c</field>
        <field>NATT_Quote_Special_Options__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_1_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_1_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Natt_Special_Options_Approver1</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Quote_Special_Options__c</field>
                <operation>greaterThan</operation>
                <value>0</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Application Engineer Approval</label>
        <name>Application_Engineer_Approval</name>
        <rejectionActions>
            <action>
                <name>NATT_Approver_1_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_2_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_2_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_2__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1 AND 2</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Quote_Record_Type_Developer_Name__c</field>
                <operation>startsWith</operation>
                <value>NATT_Units</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Approver_2__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Executive Account Manager Approval</label>
        <name>Executive_Account_Manager_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_2_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_3_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_3_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_3__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Approver_3__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Region Director Approval</label>
        <name>Region_Director_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_3_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_4_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_4_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_4__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Approver_4__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Director of Sales Approval</label>
        <name>Director_of_Sales_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_4_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Approver_Sales_Ops_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Approver_Sales_Ops_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Natt_Units_Approver_Sales_Ops</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Approver_Sales_Ops__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Sales OPS Leader</label>
        <name>Sales_OPS_Leader</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>Approver_Sales_Ops_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>christopher.comeaux@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>jesse.siebentritt@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>madeline.heric@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>stuart.m.johnson@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Discounted_BluEdge__c</field>
                <operation>equals</operation>
                <value>True</value>
            </criteriaItems>
        </entryCriteria>
        <label>BluEdge Team</label>
        <name>BluEdge_Team</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>The approval should be based the combination of Product Family , Unit , Total Individual Unit Price without services and Quote value.</description>
    <emailTemplate>unfiled$public/NATT_Discount_approval_notification</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>AND(BEGINS(RecordType.DeveloperName,&quot;NATT_Units_Quote&quot;),
OR(ISPICKVAL(SBQQ__Status__c,&apos;Draft&apos;),
ISPICKVAL(SBQQ__Status__c,&apos;Rejected&apos;)),
OR(AND(NATT_Latest_Requested_Ship_Date__c &gt;= TODAY(), ISPICKVAL(SBQQ__Type__c,&apos;Quote&apos;)),
ISPICKVAL(SBQQ__Type__c,&apos;Amendment&apos;)))</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>NATT_Final_Approval_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_Quote_Request_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Pending_Approval</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Unit_Quote_Approval_Submission_Notification</name>
            <type>Alert</type>
        </action>
    </initialSubmissionActions>
    <label>NATT Unit Quote Approval Final V2 - New</label>
    <processOrder>6</processOrder>
    <recallActions>
        <action>
            <name>NATT_Approver_1_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_2_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_3_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_4_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_5_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Draft</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
