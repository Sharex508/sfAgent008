<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Owner</field>
        <field>SBQQ__Account__c</field>
        <field>SBQQ__SalesRep__c</field>
        <field>Name</field>
        <field>NATT_End_Customer_Company__c</field>
        <field>NATT_Total_Discount__c</field>
        <field>NATT_eSolutions_Plans_For_Email__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_2_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_2_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_2__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>0</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>Executive Account Manager Approval</label>
        <name>Executive_Account_Manager_Approval</name>
        <rejectionActions>
            <action>
                <name>NATT_Approver_2_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_3_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_3_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_3__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>10</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>Region Director Approval</label>
        <name>Region_Director_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_3_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_4_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_4_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_4__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>25</value>
            </criteriaItems>
        </entryCriteria>
        <label>Director of Sales Approval</label>
        <name>Director_of_Sales_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_4_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>Approval based on the correct thresholds so that I can complete my Lynx Fleet Quote - v2</description>
    <emailTemplate>unfiled$public/NATT_eSolutions_Approver_Order_Summary_1629227416844</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>AND(
RecordType.DeveloperName = &apos;NATT_eSolutions&apos;,
NATT_eSolutions_Total_Plans__c &gt; 0,
OR(
ISPICKVAL(SBQQ__Status__c,&apos;Approval Required&apos;),
ISPICKVAL(SBQQ__Status__c,&apos;No Approval Required&apos;))
)</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>NATT_eSolutions_Customer_T_C</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_eSolutions_Status_Update</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_eSolutions_Status_Update</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_eSolutions_Status_Update_eSolutions_Team_Only</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Pending_Approval</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>NATT Lynx Fleet Quote Approval Final</label>
    <processOrder>3</processOrder>
    <recallActions>
        <action>
            <name>NATT_Approver_1_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_2_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_3_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_4_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_5_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_eSolutions_Status_Update</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Approval_Required</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
