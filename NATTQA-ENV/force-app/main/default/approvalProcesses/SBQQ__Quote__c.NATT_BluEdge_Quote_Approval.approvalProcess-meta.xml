<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>SBQQ__Account__c</field>
        <field>NATT_End_Customer_Company__c</field>
        <field>Name</field>
        <field>Owner</field>
        <field>SBQQ__ListAmount__c</field>
        <field>SBQQ__NetAmount__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>christopher.comeaux@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>jesse.siebentritt@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>madeline.heric@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <approver>
                <name>stuart.m.johnson@carrier.com.corp</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>Approval required for all BluEdge quotes</description>
        <label>Approval Required</label>
        <name>Approval_Required</name>
    </approvalStep>
    <description>For Approving BluEdge Aftermarket and Extension Quotes</description>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>AND(
RecordType.DeveloperName= &quot;NATT_BluEdge&quot;,
OR(ISPICKVAL(SBQQ__Status__c,&apos;Draft&apos;),
ISPICKVAL(SBQQ__Status__c,&apos;Rejected&apos;)
)
)</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>NATT_BluEdge_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_BluEdge_Quote_Status_Update</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_BluEdge_Quote_Approval_Submission_Notification</name>
            <type>Alert</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Pending_Approval</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>NATT BluEdge Quote Approval</label>
    <processOrder>2</processOrder>
    <recallActions>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Quote_Request_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Draft</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
