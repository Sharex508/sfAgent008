<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>SBQQ__Account__c</field>
        <field>NATT_End_Customer_Company__c</field>
        <field>Name</field>
        <field>Owner</field>
        <field>NATT_Total_Discount__c</field>
        <field>NATT_Quote_Special_Options__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_1_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_1_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_1__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Quote_Special_Options__c</field>
                <operation>greaterThan</operation>
                <value>0</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Application Engineer Approval</label>
        <name>Application_Engineer_Approval</name>
        <rejectionActions>
            <action>
                <name>NATT_Approver_1_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_2_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_2_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_2__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>0</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>USD 0</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Executive Area Manager Approval</label>
        <name>Executive_Area_Manager_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_2_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_3_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_3_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_3__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>(1 AND 2 AND 3) OR (4  AND 5 AND 6) OR (7 AND 8 AND 9)</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>lessOrEqual</operation>
                <value>10</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>lessOrEqual</operation>
                <value>&quot;USD 100,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Diesel Truck,Direct Drive</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Trailer,Solara</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>lessOrEqual</operation>
                <value>15</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>lessOrEqual</operation>
                <value>&quot;USD 200,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>lessOrEqual</operation>
                <value>7.5</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>lessOrEqual</operation>
                <value>&quot;USD 100,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>APU</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Regional Director Approval</label>
        <name>Regional_Director_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_3_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_4_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_4_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_4__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>Unanimous</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>((1 OR 2) AND 3 AND 4) OR ((5 OR 6) AND 7 AND 8) OR ((9 OR 10) AND 11 AND 12)</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>20</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>lessOrEqual</operation>
                <value>35</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>lessOrEqual</operation>
                <value>&quot;USD 2,500,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Diesel Truck,Direct Drive</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>40</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>lessOrEqual</operation>
                <value>60</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>lessOrEqual</operation>
                <value>&quot;USD 5,000,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Trailer,Solara</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>15</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>lessOrEqual</operation>
                <value>30</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>lessThan</operation>
                <value>&quot;USD 2,500,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>APU</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Director of Sales Approval</label>
        <name>Director_of_Sales_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_4_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>NATT_Approver_6_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NATT_Approver_6_Approved_Date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>NATT_Approver_6__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>(1 AND 2 AND 3) OR (4 AND 5 AND 6) OR (7 AND 8 AND 9)</booleanFilter>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>35</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 2,500,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Diesel Truck,Direct Drive</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>60</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Net_Amount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 5,000,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>Trailer,Solara</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.NATT_Total_Discount__c</field>
                <operation>greaterThan</operation>
                <value>30</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.SBQQ__NetAmount__c</field>
                <operation>greaterThan</operation>
                <value>&quot;USD 2,500,000&quot;</value>
            </criteriaItems>
            <criteriaItems>
                <field>SBQQ__Quote__c.zDeleteNATT_Product_Family__c</field>
                <operation>equals</operation>
                <value>APU</value>
            </criteriaItems>
        </entryCriteria>
        <label>VP or CFO Approval</label>
        <name>VP_or_CFO_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>NATT_Approver_6_Rejected</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>Approval based on the correct thresholds so that I can complete my Unit quote</description>
    <emailTemplate>unfiled$public/NATT_Discount_approval_notification</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <formula>AND(
RecordType.DeveloperName = &apos;NATT_Units_Quote&apos;,
TEXT(SBQQ__Status__c) =  &apos;Approval Required&apos;,
NATT_Quote_Special_Options__c &gt; 0)</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>NATT_Final_Approval_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NATT_Final_Approval_Date_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>NATT_Quote_Request_Date</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Status_Pending_Approval</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>NATT Unit Quote Approval V5</label>
    <processOrder>3</processOrder>
    <recallActions>
        <action>
            <name>NATT_Approver_1_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_2_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_3_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_4_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>NATT_Approver_5_Approved_Blank</name>
            <type>FieldUpdate</type>
        </action>
        <action>
