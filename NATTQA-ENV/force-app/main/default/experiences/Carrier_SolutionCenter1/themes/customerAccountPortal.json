  "customCSS" : "@media only screen and (min-width: 1200px) {\n.cHeaderTop {\nbackground-image: url('/sfsites/c/resource/NATT_Community_Assets/CommunityAssets/bg-header5.png');\nbackground-repeat: no-repeat;\npadding-top: 0 !important;\nheight: 150px;\nwidth:100%;\n}\n\n.cHeaderTopInternalWrapper {\ndisplay: block;\nheight: inherit;\npadding: 0 !important;\n}\n\n\n\n.cLogo {\ndisplay: none;\n\n}\n\n\n\n.cptNavBar {\n/*background: #1B347E;*/\nbottom: 0;\nposition: absolute;\nwidth: 100%;\n}\n\n\n\n.siteforceCptBody .comm-navigation {\nmax-width: 100% !important;\n}\n\n\n\n.forceCommunityGlobalNavigation>* {\nmargin: 0 !important;\n}\n\n.comm-navigation__item > button, .comm-navigation__item > a {\n/*color: #fff !important;*/\ntext-transform: uppercase !important;\n}\n\n/*.comm-navigation__item a[data-type=\"home\"] {\ncolor: #fff !important;\n}*/\n\n\n\n.comm-navigation__item ul li.slds-list__item button {\ncolor: #1B347E !important;\n}\n\n\n\n.cSearchContainer {\nposition: absolute;\nright: 20%;\ntop: 10px;\n}\n\n\n\n.cNotifications {\nposition: absolute;\nright: 0;\ntop: 15px;\n}\n\n\n\n.cProfileMenu {\nposition: absolute;\nright: 3%;\ntop: 5px;\n}\n\n\n\n.selfServiceUserProfileMenu a.trigger-link {\ncolor: white !important;\n}\n\n\n\n.forceCommunityGlobalSearchInput .inputWrapper {\nbackground: white;\n}\n\n\n\n.forceSearchInputDesktop .contentWrapper {\nborder-radius: 50px !important;\n}\n\n\n\n.slds-icon-utility-notification svg[data-key=\"notification\"] {fill: white !important;}\n\n.siteforceContentArea {\npadding: 0 100px;\n}\n\n.siteforceContentArea.siteforceSldsOneColLayout, .siteforceContentArea.siteforceDynamicLayout {\npadding: 0 !important;\n}\n}\n\n\n\n@media only screen and (max-width: 30em) {\n#CustomerPortalTemplate {\noverflow-x: hidden !important;\n}\n\n.siteforceCptBody .cHeader .cAltToggleNav .slds-button__icon {\ncolor:white!important;\n}\n\n.siteforceCptBody .cHeader .cSearchInvokeMobile .slds-icon {\nfill:white!important;\n}\n\n.siteforceCptBody .cHeader .selfServiceProfileMenuTrigger .profileName{\ncolor:white!important;\n}\n}\n\n\n\n@media only screen and (min-width: 30em) and (max-width: 48em) {\n.cSearchContainer {\nposition: absolute;\nright: 20%;\ntop: 10px;\n}\n\n\n\n.cNotifications {\nposition: absolute;\nright: 14%;\ntop: 15px;\n}\n\n\n\n.cProfileMenu {\nposition: absolute;\nright: 1%;\ntop: 15px;\n}\n\n.siteforceContentArea {\npadding: 0 !important;\n}\n\n.siteforceCptBody .cHeader .cAltToggleNav .slds-button__icon {\ncolor:white;\n}\n\n.siteforceCptBody .cHeader .cSearchInvokeMobile .slds-icon {\nfill:white;\n}\n\n.siteforceCptBody .cHeader .selfServiceProfileMenuTrigger .profileName{\ncolor:white;\n}\n}\n\n\n\n@media screen and (min-width: 1024px) and (max-width: 1366px) {\n.siteforceContentArea {\npadding: 0 !important;\n}\n\n\n\n}",
