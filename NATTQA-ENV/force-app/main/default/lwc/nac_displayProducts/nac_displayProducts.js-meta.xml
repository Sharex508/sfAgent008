<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>55.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>NAC Display Product List</masterLabel>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property 
                label="Select Type" 
                name="type" 
                type="String" 
                datasource="displayRecentlyOrderedProducts" 
                description="Select the business type for the component"
                default="displayRecentlyOrderedProducts"/>
            <property
                name="numofTiles"
                type="Integer"
                label="Number of Tiles"
                description="Display the number of tiles to display"
                default="4"
            />
            <property
                name="effectiveAccountId"
                type="String"
                label="Effective Account Id"
                description="The ID of the account under which the user is acting (BETA)"
                default="{!CurrentUser.effectiveAccountId}"
            />
            <property
                name="resultsLayout"
                label="Results Layout"
                type="String"
                default="grid"
                datasource="java://siteforce.communitybuilder.datasource.B2BSearchResultsPanelLayoutDataSource"
            />
            <property
                name="showProductImage"
                label="Show Product Image"
                type="Boolean"
                default="true"
            />
            <property
                name="cardContentMapping"
                type="String"
                label="Fields to Show on Card"
                description="The comma-separated fields to display on the product detail page"
            />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>