<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>NATT_Upate_OrderItem_Original_JDE_Sales</fullName>
        <field>NATT_Original_JDE_Sales_Order__c</field>
        <formula>Order.NATT_JDE_Sales_Order_Number__c</formula>
        <name>NATT Upate OrderItem Original JDE Sales</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>NATT_Update_New_Original_Order_Id</fullName>
        <field>NATT_Original_Order_Id__c</field>
        <formula>Order.NATT_Original_Order_Id__c</formula>
        <name>NATT Update New Original Order Id</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>NATT Update Original JDE Sales Item</fullName>
        <actions>
            <name>NATT_Upate_OrderItem_Original_JDE_Sales</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>AND( ISPICKVAL(Order.Type,&quot;New&quot;), ISBLANK(NATT_Original_JDE_Sales_Order__c), NOT(ISBLANK(Order.NATT_JDE_Sales_Order_Number__c)) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>NATT Update Original Order Id Item</fullName>
        <actions>
            <name>NATT_Update_New_Original_Order_Id</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>ISPICKVAL(Order.Type,&quot;New&quot;) &amp;&amp; ISBLANK(NATT_Original_Order_Id__c)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
