    <fieldUpdates>
        <fullName>NATT_Set_JDE_Update_field_to_Completed</fullName>
        <description>When the approval process ends, set the JDE Update field to &quot;Completed&quot;.</description>
        <field>NATT_JDE_Update__c</field>
        <literalValue>Completed</literalValue>
        <name>Set JDE Update field to Completed</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>NATT_Set_JDE_Update_field_to_None</fullName>
        <description>When the Account is rejected set the JDE field to none</description>
        <field>NATT_JDE_Update__c</field>
        <name>Set JDE Update field to None</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>NATT_Set_JDE_Update_field_to_Pending</fullName>
        <description>When the approval process starts, the the JDE Update account field to &quot;pending&quot;.</description>
        <field>NATT_JDE_Update__c</field>
        <literalValue>Pending</literalValue>
        <name>Set JDE Update field to Pending</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>NATT_Set_Send_for_Approval_field_false</fullName>
        <description>Set the &quot;Send for Approval&quot; field to false when the record is rejected</description>
        <field>NATT_Send_for_Approval__c</field>
        <literalValue>0</literalValue>
        <name>Set Send for Approval field to false</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
</Workflow>
