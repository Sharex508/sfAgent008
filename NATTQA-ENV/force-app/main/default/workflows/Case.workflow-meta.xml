    <rules>
        <fullName>NATT Assign Application Engineering case to Application Engineering queue</fullName>
        <actions>
            <name>NATT_Assign_Application_Engineering_case</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>User.ProfileId</field>
            <operation>equals</operation>
            <value>NATT Full Access Community</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.RecordTypeId</field>
            <operation>equals</operation>
            <value>Application Engineering</value>
        </criteriaItems>
        <description>NATT Assign Application Engineering case to Application Engineering queue. when Profile is NATT Full Access Community</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
