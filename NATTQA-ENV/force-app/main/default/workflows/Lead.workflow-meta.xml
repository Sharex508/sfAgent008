    <fieldUpdates>
        <fullName>NATT_Update_Lead_Company</fullName>
        <field>Company</field>
        <formula>Owner:User.Contact.Account.Name</formula>
        <name>NATT Update Lead Company</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>NATT Update Lead Account Field</fullName>
        <actions>
            <name>NATT_Update_Lead_Company</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>If the user is a community user with natt then the company is set for them.</description>
        <formula>NOT(ISBLANK(Owner:User.Contact.Account.Name)) &amp;&amp; Company &lt;&gt; Owner:User.Contact.Account.Name</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Sender - Lead Accepted</fullName>
        <actions>
            <name>Sender_Lead_Accepted</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Lead.HBI_Lead_Status__c</field>
            <operation>equals</operation>
            <value>Accepted</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
